  m_Name: Event_Day2_Fork
  m_EditorClassIdentifier: Assembly-CSharp::Story.Data.EventSO
  eventText: "\u0422\u0440\u043E\u043F\u0430 \u0440\u0430\u0437\u0434\u0432\u0430\u0438\u0432\u0430\u0435\u0442\u0441\u044F.
    \u041B\u0435\u0432\u0430\u044F \u0432\u0435\u0434\u0451\u0442 \u0432 \u0447\u0430\u0449\u0443
    \u2014 \u0442\u0451\u043C\u043D\u0443\u044E \u0438 \u0442\u0438\u0445\u0443\u044E.
    \u041F\u0440\u0430\u0432\u0430\u044F \u2014 \u043F\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u043C\u0443
    \u0442\u0440\u0430\u043A\u0442\u0443, \u0433\u0434\u0435 \u0432\u0438\u0434\u043D\u044B
    \u0441\u043B\u0435\u0434\u044B \u043A\u043E\u043B\u0451\u0441."
  totalPenalty: -12
  actionVerb: "\u0412\u044B\u0431\u0440\u0430\u0442\u044C"
  actionVerbPast: "\u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0448\u044C"
  defaultApproachAdverb: "\u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  defaultApproachAdverbPast: "\u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  defaultHpWeight: 1
  defaultPowWeight: 1
  defaultSanWeight: 1
  defaultSupportAdverb: "\u0437\u043D\u0430\u043D\u0438\u0435\u043C"
  defaultPenaltyReduction: 0
  baseChance: 0.3
  positiveOutcomeText: "\u0438 \u0442\u044B \u0437\u0430\u043C\u0435\u0447\u0430\u0435\u0448\u044C
    \u0441\u0442\u0430\u0440\u044B\u0439 \u0437\u043D\u0430\u043A \u043D\u0430 \u043A\u0430\u043C\u043D\u0435.
    \u041D\u0430\u0445\u043E\u0434\u0438\u0448\u044C [support] \u0438 [support]."
  negativeOutcomeText: "\u043D\u043E \u043E\u0431\u0430 \u043F\u0443\u0442\u0438
    \u0432\u044B\u0433\u043B\u044F\u0434\u044F\u0442 \u043E\u043F\u0430\u0441\u043D\u043E.
    \u0422\u044B \u0438\u0434\u0451\u0448\u044C \u043F\u043E \u0442\u0440\u0430\u043A\u0442\u0443
    \u043D\u0430\u0443\u0433\u0430\u0434."
  synergies:
  - approachArchetype: 1
    supportArchetype: 1
    bonusChance: 0.25
    positiveOutcomeText: "\u0438 \u0442\u044B \u0437\u0430\u043C\u0435\u0447\u0430\u0435\u0448\u044C
      \u0441\u043A\u0440\u044B\u0442\u044B\u0439 \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440:
      \u043C\u043E\u0445 \u043D\u0430 \u043A\u0430\u043C\u043D\u0435 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
      \u0432 \u0447\u0430\u0449\u0443. \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0437\u043D\u0430\u043D\u0438\u044F \u043D\u0435
      \u0441\u043F\u0430\u0441\u0430\u044E\u0442 \u043E\u0442 \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0441\u0442\u0438.
      \u041E\u0431\u0430 \u043F\u0443\u0442\u0438 \u043A\u0430\u0436\u0443\u0442\u0441\u044F
      \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E \u043E\u043F\u0430\u0441\u043D\u044B\u043C\u0438."
  - approachArchetype: 2
    supportArchetype: 1
    bonusChance: 0.15
    positiveOutcomeText: "\u0438 \u0442\u044B \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0435\u0448\u044C
      \u0441\u0442\u0430\u0440\u0438\u043A\u0430 \u043D\u0430 \u043E\u0431\u043E\u0447\u0438\u043D\u0435.
      \u041E\u043D \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u043D\u0430
      \u0447\u0430\u0449\u0443. \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0441\u0442\u0430\u0440\u0438\u043A \u043B\u0438\u0448\u044C
      \u043F\u043E\u0436\u0438\u043C\u0430\u0435\u0442 \u043F\u043B\u0435\u0447\u0430\u043C\u0438.
      \xAB\u042F \u0437\u0434\u0435\u0441\u044C \u043D\u0435 \u0436\u0443\u0432\u0443.\xBB"
  - approachArchetype: 0
    supportArchetype: 0
    bonusChance: -0.15
    positiveOutcomeText: "\u0438 \u0442\u044B \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0435\u0448\u044C\u0441\u044F
      \u0432 \u0447\u0430\u0449\u0443 \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E.
      \u0414\u043E\u0440\u043E\u0433\u0430 \u0435\u0441\u0442\u044C, \u043D\u043E
      \u0441\u043B\u043E\u0436\u043D\u0430. \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support]."
    negativeOutcomeText: "\u043D\u043E \u0441\u0438\u043B\u0430 \u043D\u0435 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442
      \u0432\u044B\u0431\u0440\u0430\u0442\u044C \u043F\u0443\u0442\u044C. \u0422\u044B
      \u0431\u0440\u0451\u0434\u0451\u0448\u044C \u043F\u043E \u0442\u0440\u0430\u043A\u0442\u0443
      \u043D\u0430\u0443\u0433\u0430\u0434."
