  positiveOutcomeText: "\u0438 \u0441\u0442\u0430\u0440\u0438\u043A \u043A\u0438\u0432\u0430\u0435\u0442:
    \xAB\u0411\u0435\u0440\u0438, \u044D\u0442\u043E \u0442\u0435\u0431\u0435 \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u0442\u0441\u044F\xBB.
