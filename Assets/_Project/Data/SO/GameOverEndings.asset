  m_Name: GameOverEndings
  m_EditorClassIdentifier: Assembly-CSharp::Story.Data.GameOverEndingsSO
  healthDeath: "\u0420\u0430\u043D\u044B \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
    \u0441\u043C\u0435\u0440\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438. \u0422\u0440\u0430\u043A\u0442
    \u0443\u0442\u0430\u0438\u043B \u0432 \u0441\u0435\u0431\u0435 \u0435\u0449\u0451
    \u043E\u0434\u043D\u043E\u0433\u043E \u043F\u0443\u0442\u043D\u0438\u043A\u0430."
  suppliesDeath: "\u0413\u043E\u043B\u043E\u0434 \u0438 \u0438\u0441\u0442\u043E\u0449\u0435\u043D\u0438\u0435
    \u0432\u0437\u044F\u043B\u0438 \u0441\u0432\u043E\u0451. \u0412\u044B \u0443\u043F\u0430\u043B\u0438
    \u0443 \u043E\u0431\u043E\u0447\u0438\u043D\u044B, \u0442\u0430\u043A \u0438
    \u043D\u0435 \u0434\u043E\u0431\u0440\u0430\u0432\u0448\u0438\u0441\u044C \u0434\u043E
    \u0446\u0435\u043B\u0438."
  sanityDeath: "\u0412\u0430\u0448 \u0440\u0430\u0441\u0441\u0443\u0434\u043E\u043A
    \u0440\u0430\u0441\u0442\u0432\u043E\u0440\u0438\u043B\u0441\u044F \u0432 \u043F\u0443\u0441\u0442\u043E\u0442\u0435
    \u0442\u0440\u0430\u043A\u0442\u0430. \u0413\u0434\u0435-\u0442\u043E \u0442\u0430\u043C
    \u0435\u0449\u0451 \u0431\u0440\u0435\u0434\u0451\u0442 \u0432\u0430\u0448\u0435
    \u0442\u0435\u043B\u043E \u2014 \u043D\u043E \u0432\u0430\u0441 \u0443\u0436\u0435
    \u043D\u0435\u0442."
  fallback: "\u041F\u0443\u0442\u044C \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0434\u043E\u043B\u0433\u0438\u043C."
