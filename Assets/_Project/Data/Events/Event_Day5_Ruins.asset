  m_Name: Event_Day5_Ruins
  m_EditorClassIdentifier: Assembly-CSharp::Story.Data.EventSO
  eventText: "\u0421\u043B\u0435\u0434\u0443\u044F \u0441\u043B\u043E\u0432\u0430\u043C
    \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A\u0430, \u0442\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
    \u0434\u0440\u0435\u0432\u043D\u0438\u0435 \u0440\u0443\u0438\u043D\u044B. \u0421\u0442\u0435\u043D\u044B
    \u043F\u043E\u043A\u0440\u044B\u0442\u044B \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u0430\u043C\u0438,
    \u0430 \u0432 \u0433\u043B\u0443\u0431\u0438\u043D\u0435 \u043C\u0435\u0440\u0446\u0430\u0435\u0442
    \u0441\u0432\u0435\u0442."
  totalPenalty: -16
  actionVerb: "\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C"
  actionVerbPast: "\u0438\u0441\u0441\u043B\u0435\u0434\u0443\u0435\u0448\u044C"
  defaultApproachAdverb: "\u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  defaultApproachAdverbPast: "\u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  defaultHpWeight: 0
  defaultPowWeight: 1
  defaultSanWeight: 2
  defaultSupportAdverb: "\u0437\u043D\u0430\u043D\u0438\u0435\u043C"
  defaultPenaltyReduction: 0
  baseChance: 0.3
  positiveOutcomeText: "\u0438 \u0441\u0440\u0435\u0434\u0438 \u043A\u0430\u043C\u043D\u0435\u0439
    \u0442\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C \u0442\u0430\u0439\u043D\u0438\u043A.
    \u0412\u043D\u0443\u0442\u0440\u0438 \u2014 [support] \u0438 [approach]."
  negativeOutcomeText: "\u043D\u043E \u0440\u0443\u0438\u043D\u044B \u0441\u043E\u0434\u0440\u043E\u0433\u0430\u044E\u0442\u0441\u044F.
    \u0422\u044B \u0432\u044B\u0431\u0435\u0433\u0430\u0435\u0448\u044C \u0434\u043E
    \u043E\u0431\u0432\u0430\u043B\u0430, \u043F\u043E\u0442\u0435\u0440\u044F\u0432
    \u0432\u0440\u0435\u043C\u044F."
  synergies:
  - approachArchetype: 1
    supportArchetype: 1
    bonusChance: 0.25
    positiveOutcomeText: "\u0438 \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u0430
      \u043E\u0436\u0438\u0432\u0430\u044E\u0442. \u0422\u044B \u0447\u0438\u0442\u0430\u0435\u0448\u044C
      \u0442\u0430\u0439\u043D\u043E\u0435 \u0441\u043B\u043E\u0432\u043E \u0438
      \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C [support] \u0438 [approach]."
    negativeOutcomeText: "\u043D\u043E \u0437\u043D\u0430\u043D\u0438\u0435 \u043D\u0435
      \u0441\u043F\u0430\u0441\u0430\u0435\u0442 \u043E\u0442 \u043B\u043E\u0432\u0443\u0448\u043A\u0438.
      \u0422\u044B \u0432\u044B\u0431\u0435\u0433\u0430\u0435\u0448\u044C \u0438\u0437
      \u043E\u0431\u0432\u0430\u043B\u0430."
  - approachArchetype: 2
    supportArchetype: 1
    bonusChance: 0.1
    positiveOutcomeText: "\u0438 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044F
      \u0432\u0435\u0434\u0451\u0442 \u0442\u0435\u0431\u044F. \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support] \u0438 [approach]."
    negativeOutcomeText: "\u043D\u043E \u0440\u0443\u0438\u043D\u044B \u043D\u0435
      \u0438\u043C\u0435\u044E\u0442 \u0434\u0435\u043B\u0430 \u0441 \u0447\u0443\u0432\u0441\u0442\u0432\u0430\u043C\u0438.
      \u0422\u044B \u0432\u044B\u0431\u0435\u0433\u0430\u0435\u0448\u044C \u0432
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u043C\u043E\u043C\u0435\u043D\u0442."
  - approachArchetype: 0
    supportArchetype: 0
    bonusChance: -0.15
    positiveOutcomeText: "\u0438 \u0441\u0438\u043B\u0430 \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0435\u0442
      \u043F\u0443\u0442\u044C. \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support]."
    negativeOutcomeText: "\u043D\u043E \u0440\u0443\u0438\u043D\u044B \u0441\u043E\u0434\u0440\u043E\u0433\u0430\u044E\u0442\u0441\u044F.
      \u0422\u044B \u0441\u043B\u044B\u0448\u0438\u0448\u044C \u0442\u0440\u0435\u0449\u0438\u043D\u044B."
