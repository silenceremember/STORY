  m_Name: Event_Day9_Voice
  m_EditorClassIdentifier: Assembly-CSharp::Story.Data.EventSO
  eventText: "\u0413\u043E\u043B\u043E\u0441 \u0438\u0437-\u043F\u043E\u0434 \u0437\u0435\u043C\u043B\u0438
    \u043E\u0431\u0435\u0449\u0430\u0435\u0442 \u0441\u0438\u043B\u0443: \xAB\u0414\u0430\u0439
    \u043C\u043D\u0435 \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C...
    \u0438 \u044F \u0434\u0430\u043C \u0442\u0435\u0431\u0435 \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435.\xBB"
  totalPenalty: -20
  actionVerb: "\u041E\u0442\u0432\u0435\u0442\u0438\u0442\u044C"
  actionVerbPast: "\u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0448\u044C"
  defaultApproachAdverb: "\u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  defaultApproachAdverbPast: "\u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  defaultHpWeight: 1
  defaultPowWeight: 1
  defaultSanWeight: 3
  defaultSupportAdverb: "\u0441\u043B\u043E\u0432\u043E\u043C"
  defaultPenaltyReduction: 0
  baseChance: 0.2
  positiveOutcomeText: "\u0438 \u0433\u043E\u043B\u043E\u0441 \u0441\u0442\u0438\u0445\u0430\u0435\u0442.
    \u041D\u0430 \u0437\u0435\u043C\u043B\u0435 \u2014 [support] \u0438 [approach].
    \u0421\u0434\u0435\u043B\u043A\u0430 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0430."
  negativeOutcomeText: "\u043D\u043E \u0433\u043E\u043B\u043E\u0441 \u0445\u043E\u0445\u043E\u0447\u0435\u0442
    \u0438 \u0437\u0430\u043C\u043E\u043B\u043A\u0430\u0435\u0442. \u0417\u0435\u043C\u043B\u044F
    \u0434\u0440\u043E\u0436\u0438\u0442 \u043F\u043E\u0434 \u043D\u043E\u0433\u0430\u043C\u0438."
  synergies:
  - approachArchetype: 2
    supportArchetype: 2
    bonusChance: 0.2
    positiveOutcomeText: "\u0438 \u0433\u043E\u043B\u043E\u0441 \u0434\u043E\u0432\u043E\u043B\u0435\u043D
      \u043E\u0442\u0432\u0435\u0442\u043E\u043C. \xAB\u0421\u0434\u0435\u043B\u043A\u0430.\xBB
      \u041D\u0430 \u0437\u0435\u043C\u043B\u0435 \u2014 [support] \u0438 [approach]."
    negativeOutcomeText: "\u043D\u043E \u0433\u043E\u043B\u043E\u0441 \u0441\u043C\u0435\u0451\u0442\u0441\u044F:
      \xAB\u0421\u043B\u043E\u0432\u0430 \u2014 \u0434\u0435\u0448\u0451\u0432\u044B\u0439
      \u0442\u043E\u0432\u0430\u0440.\xBB \u0417\u0435\u043C\u043B\u044F \u0434\u0440\u043E\u0436\u0438\u0442."
  - approachArchetype: 1
    supportArchetype: 2
    bonusChance: 0.1
    positiveOutcomeText: "\u0438 \u0442\u044B \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E
      \u0442\u043E\u0440\u0433\u0443\u0435\u0448\u044C\u0441\u044F. \u0413\u043E\u043B\u043E\u0441
      \u0441\u043E\u0433\u043B\u0430\u0448\u0430\u0435\u0442\u0441\u044F. \u041D\u0430
      \u0437\u0435\u043C\u043B\u0435 \u2014 [support] \u0438 [approach]."
    negativeOutcomeText: "\u043D\u043E \u0433\u043E\u043B\u043E\u0441 \u0432\u0438\u0434\u0438\u0442
      \u0442\u0432\u043E\u0438 \u0440\u0430\u0441\u0447\u0451\u0442\u044B. \xAB\u0422\u044B
      \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0443\u043C\u0451\u043D \u0434\u043B\u044F
      \u0447\u0435\u0441\u0442\u043D\u043E\u0439 \u0441\u0434\u0435\u043B\u043A\u0438.\xBB"
  - approachArchetype: 0
    supportArchetype: 0
    bonusChance: -0.2
    positiveOutcomeText: "\u0438 \u0433\u043E\u043B\u043E\u0441 \u0438\u0441\u043F\u0443\u0433\u0430\u043D
      \u0430\u0433\u0440\u0435\u0441\u0441\u0438\u0435\u0439. \u041E\u043D \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
      [support] \u0438 \u0437\u0430\u043C\u043E\u043B\u043A\u0430\u0435\u0442."
    negativeOutcomeText: "\u043D\u043E \u0433\u043E\u043B\u043E\u0441 \u0445\u043E\u0445\u043E\u0447\u0435\u0442
      \u043D\u0430\u0434 \u0441\u0438\u043B\u043E\u0439: \xAB\u0413\u043B\u0443\u043F\u0435\u0446!\xBB
      \u0417\u0435\u043C\u043B\u044F \u0434\u0440\u043E\u0436\u0438\u0442."
