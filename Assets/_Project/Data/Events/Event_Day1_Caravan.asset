  m_Name: Event_Day1_Caravan
  m_EditorClassIdentifier: Assembly-CSharp::Story.Data.EventSO
  eventText: "\u0423 \u0432\u043E\u0440\u043E\u0442 \u0441\u0442\u043E\u0438\u0442
    \u043E\u0431\u043E\u0437. \u0422\u043E\u0440\u0433\u043E\u0432\u0435\u0446 \u043D\u0430\u0433\u0440\u0443\u0436\u0430\u0435\u0442
    \u043F\u043E\u0432\u043E\u0437\u043A\u0443 \u0438 \u0437\u043E\u0432\u0451\u0442:
    \xAB\u041F\u043E\u043C\u043E\u0433\u0438 \u2014 \u043F\u043E\u0434\u0435\u043B\u044E\u0441\u044C,
    \u0447\u0435\u043C \u0441\u043C\u043E\u0433\u0443.\xBB"
  totalPenalty: -8
  actionVerb: "\u041F\u043E\u043C\u043E\u0447\u044C"
  actionVerbPast: "\u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0448\u044C"
  defaultApproachAdverb: "\u043E\u0442\u043A\u0440\u044B\u0442\u043E"
  defaultApproachAdverbPast: "\u043E\u0442\u043A\u0440\u044B\u0442\u043E"
  defaultHpWeight: 1
  defaultPowWeight: 0
  defaultSanWeight: 1
  defaultSupportAdverb: "\u0441\u0438\u043B\u043E\u0439"
  defaultPenaltyReduction: 3
  baseChance: 0.5
  positiveOutcomeText: "\u0438 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446 \u043F\u0440\u043E\u0442\u044F\u0433\u0438\u0432\u0430\u0435\u0442
    \u043C\u0435\u0448\u043E\u043A: \xAB\u0414\u0435\u0440\u0436\u0438, \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u0442\u0441\u044F
    \u0432 \u043F\u0443\u0442\u0438\xBB. \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
    [support] \u0438 [support]."
  negativeOutcomeText: "\u043D\u043E \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
    \u043B\u0438\u0448\u044C \u043A\u0430\u0447\u0430\u0435\u0442 \u0433\u043E\u043B\u043E\u0432\u043E\u0439.
    \u041F\u043E\u0432\u043E\u0437\u043A\u0430 \u0443\u0435\u0437\u0436\u0430\u0435\u0442
    \u0431\u0435\u0437 \u0442\u0435\u0431\u044F."
  synergies:
  - approachArchetype: 0
    supportArchetype: 0
    bonusChance: 0.25
    positiveOutcomeText: "\u0438 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
      \u0448\u043B\u0451\u043F\u0430\u0435\u0442 \u043F\u043E \u043F\u043B\u0435\u0447\u0443:
      \xAB\u0418\u043D\u043E\u0433\u0434\u0430 \u043D\u0443\u0436\u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u0430\u044F
      \u0441\u0438\u043B\u0430!\xBB \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
      \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E
      \u043A\u043E\u0441\u0438\u0442\u0441\u044F. \xAB\u0421\u043A\u043E\u043B\u044C\u043A\u043E
      \u0432\u0435\u0449\u0435\u0439 \u043F\u043E\u0442\u0435\u0440\u044F\u043B?\xBB"
  - approachArchetype: 2
    supportArchetype: 2
    bonusChance: 0.1
    positiveOutcomeText: "\u0438 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
      \u0443\u043B\u044B\u0431\u0430\u0435\u0442\u0441\u044F: \xAB\u0425\u043E\u0440\u043E\u0448\u0438\u0439
      \u043D\u0430\u0440\u043E\u0434.\xBB \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
      \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0438\u0432\u0430\u0435\u0442.
      \xAB\u041F\u043E\u043C\u043E\u0433\u0430\u0442\u044C \u043A\u0430\u0436\u0434\u044B\u0439
      \u043C\u043E\u0436\u0435\u0442.\xBB"
  - approachArchetype: 1
    supportArchetype: 0
    bonusChance: -0.1
    positiveOutcomeText: "\u0438 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
      \u0432\u044B\u0434\u0430\u0451\u0442 \u043C\u0435\u043D\u044C\u0448\u0435,
      \u0447\u0435\u043C \u043C\u043E\u0433 \u0431\u044B. \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support]."
    negativeOutcomeText: "\u043D\u043E \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
      \u0437\u043D\u0430\u0435\u0442: \u0440\u0430\u0431\u043E\u0442\u0430 \u0431\u0435\u0437
      \u0434\u0443\u0448\u0438 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u0430."
