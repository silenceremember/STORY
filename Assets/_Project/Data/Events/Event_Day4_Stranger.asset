  m_EditorClassIdentifier: Assembly-CSharp::Story.Data.EventSO
  eventText: "\u0423 \u0443\u0446\u0435\u043B\u0435\u0432\u0448\u0435\u0433\u043E
    \u043C\u043E\u0441\u0442\u0430 \u043B\u0435\u0436\u0438\u0442 \u0440\u0430\u043D\u0435\u043D\u044B\u0439.
    \u041E\u043D \u0448\u0435\u043F\u0447\u0435\u0442: \xAB\u041D\u0435 \u0445\u043E\u0434\u0438
    \u0442\u0443\u0434\u0430... \u0440\u0443\u0438\u043D\u044B... \u043B\u043E\u0432\u0443\u0448\u043A\u0430...\xBB
    \u0415\u0433\u043E \u0440\u0443\u043A\u0430 \u0442\u044F\u043D\u0435\u0442\u0441\u044F
    \u043A \u0442\u0435\u0431\u0435."
  totalPenalty: -15
  actionVerb: "\u041F\u043E\u043C\u043E\u0447\u044C"
  actionVerbPast: "\u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0448\u044C"
  defaultApproachAdverb: "\u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  defaultApproachAdverbPast: "\u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E"
  defaultHpWeight: 2
  defaultPowWeight: 1
  defaultSanWeight: 0
  defaultSupportAdverb: "\u0441\u043B\u043E\u0432\u043E\u043C"
  defaultPenaltyReduction: 0
  baseChance: 0.3
  positiveOutcomeText: "\u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0438\u0442:
    \xAB\u0412\u043E\u0437\u044C\u043C\u0438... \u044D\u0442\u043E \u043F\u043E\u043C\u043E\u0436\u0435\u0442\xBB.
    \u041E\u043D \u0434\u0430\u0451\u0442 \u0442\u0435\u0431\u0435 [support] \u0438
    [support]."
  negativeOutcomeText: "\u043D\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A
    \u043E\u0442\u0448\u0430\u0442\u044B\u0432\u0430\u0435\u0442\u0441\u044F. \u0422\u044B
    \u0443\u0445\u043E\u0434\u0438\u0448\u044C, \u043D\u0435 \u043E\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u044F\u0441\u044C."
  synergies:
  - approachArchetype: 2
    supportArchetype: 2
    bonusChance: 0.25
    positiveOutcomeText: "\u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A
      \u043F\u043B\u0430\u0447\u0435\u0442 \u043E\u0442 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u043D\u043E\u0441\u0442\u0438.
      \xAB\u0422\u044B \u0441\u043F\u0430\u0441 \u043C\u043E\u044E \u0436\u0438\u0437\u043D\u044C.\xBB
      \u041E\u043D \u0434\u0430\u0451\u0442 [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A
      \u043E\u0442\u0448\u0430\u0442\u044B\u0432\u0430\u0435\u0442\u0441\u044F: \xAB\u0422\u044B
      \u043D\u0435 \u0432\u0435\u0440\u0438\u0448\u044C \u043C\u043D\u0435, \u0434\u0430
      \u044F \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E.\xBB"
  - approachArchetype: 1
    supportArchetype: 1
    bonusChance: 0.15
    positiveOutcomeText: "\u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A
      \u0434\u043E\u0432\u0435\u0440\u044F\u0435\u0442: \xAB\u0422\u044B \u043D\u0435
      \u0442\u0430\u043A\u043E\u0439, \u043A\u0430\u043A \u0432\u0441\u0435.\xBB
      \u041E\u043D \u0434\u0430\u0451\u0442 [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A
      \u0447\u0443\u0435\u0442 \u043F\u0440\u0430\u0433\u043C\u0430\u0442\u0438\u0437\u043C.
      \xAB\u0422\u044B \u0445\u043E\u0447\u0435\u0448\u044C \u043D\u0430\u0433\u0440\u0430\u0434\u044B,
      \u0430 \u043D\u0435 \u043F\u043E\u043C\u043E\u0447\u044C.\xBB"
  - approachArchetype: 0
    supportArchetype: 0
    bonusChance: -0.2
    positiveOutcomeText: "\u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A
      \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u0435\u0442 \u0440\u0430\u043D\u044B
      \u0438 \u0432\u0441\u0442\u0430\u0451\u0442. \u041E\u043D \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
      [support]."
    negativeOutcomeText: "\u043D\u043E \u0440\u0430\u043D\u0435\u043D\u044B\u0439
      \u0438\u0441\u043F\u0443\u0433\u0430\u043D. \u0413\u0440\u0443\u0431\u0430\u044F
      \u0441\u0438\u043B\u0430 \u043D\u0435 \u043B\u0435\u0447\u0438\u0442."
