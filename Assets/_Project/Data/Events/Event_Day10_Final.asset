  eventText: "\u041A\u043E\u043D\u0435\u0446 \u043F\u0443\u0442\u0438. \u041F\u0435\u0440\u0435\u0434
    \u0442\u043E\u0431\u043E\u0439 \u2014 \u0442\u043E, \u043A \u0447\u0435\u043C\u0443
    \u0442\u044B \u0448\u0451\u043B. \u0422\u0435\u043D\u0438 \u043F\u0440\u043E\u0448\u043B\u043E\u0433\u043E
    \u0441\u0442\u043E\u044F\u0442 \u0437\u0430 \u0441\u043F\u0438\u043D\u043E\u0439.
    \u0412\u0441\u0451, \u0447\u0442\u043E \u0442\u044B \u0441\u0434\u0435\u043B\u0430\u043B,
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u0442\u0435\u0431\u044F \u0441\u044E\u0434\u0430."
