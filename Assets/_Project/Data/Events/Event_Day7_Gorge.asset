  m_Name: Event_Day7_Gorge
  m_EditorClassIdentifier: Assembly-CSharp::Story.Data.EventSO
  eventText: "\u0412 \u0443\u0437\u043A\u043E\u043C \u0443\u0449\u0435\u043B\u044C\u0435
    \u0442\u0435\u0431\u044F \u043F\u043E\u0434\u0436\u0438\u0434\u0430\u044E\u0442
    \u043C\u0430\u0440\u043E\u0434\u0451\u0440\u044B. \u041E\u043D\u0438 \u0437\u043D\u0430\u043B\u0438,
    \u0447\u0442\u043E \u0442\u044B \u043F\u0440\u043E\u0439\u0434\u0451\u0448\u044C
    \u0437\u0434\u0435\u0441\u044C \u2014 \u043A\u0442\u043E-\u0442\u043E \u0434\u043E\u043D\u0451\u0441."
  totalPenalty: -22
  actionVerb: "\u041F\u0440\u043E\u0440\u0432\u0430\u0442\u044C\u0441\u044F"
  actionVerbPast: "\u043F\u0440\u043E\u0440\u044B\u0432\u0430\u0435\u0448\u044C\u0441\u044F"
  defaultApproachAdverb: "\u043E\u0442\u0447\u0430\u044F\u043D\u043D\u043E"
  defaultApproachAdverbPast: "\u043E\u0442\u0447\u0430\u044F\u043D\u043D\u043E"
  defaultHpWeight: 2
  defaultPowWeight: 2
  defaultSanWeight: 1
  defaultSupportAdverb: "\u0441\u0438\u043B\u043E\u0439"
  defaultPenaltyReduction: 0
  baseChance: 0.25
  positiveOutcomeText: "\u0438 \u043C\u0430\u0440\u043E\u0434\u0451\u0440\u044B \u0431\u0435\u0433\u0443\u0442,
    \u0431\u0440\u043E\u0441\u0438\u0432 \u043D\u0430\u0433\u0440\u0430\u0431\u043B\u0435\u043D\u043D\u043E\u0435.
    \u0421\u0440\u0435\u0434\u0438 \u0432\u0435\u0449\u0435\u0439 \u2014 [support]
    \u0438 [support]."
  negativeOutcomeText: "\u043D\u043E \u043C\u0430\u0440\u043E\u0434\u0451\u0440\u044B
    \u0441\u0438\u043B\u044C\u043D\u0435\u0435. \u0422\u044B \u0432\u044B\u0440\u044B\u0432\u0430\u0435\u0448\u044C\u0441\u044F
    \u0441 \u043F\u043E\u0442\u0435\u0440\u044F\u043C\u0438."
  synergies:
  - approachArchetype: 0
    supportArchetype: 0
    bonusChance: 0.2
    positiveOutcomeText: "\u0438 \u043C\u0430\u0440\u043E\u0434\u0451\u0440\u044B
      \u0431\u0435\u0433\u0443\u0442. \u0421\u0440\u0435\u0434\u0438 \u0432\u0435\u0449\u0435\u0439
      \u2014 [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0441\u0438\u043B\u0430 \u0431\u0435\u0437
      \u0442\u0430\u043A\u0442\u0438\u043A\u0438 \u0438\u0441\u0442\u043E\u0449\u0430\u0435\u0442\u0441\u044F.
      \u0422\u044B \u0432\u044B\u0440\u044B\u0432\u0430\u0435\u0448\u044C\u0441\u044F
      \u0441 \u043F\u043E\u0442\u0435\u0440\u044F\u043C\u0438."
  - approachArchetype: 1
    supportArchetype: 0
    bonusChance: 0.15
    positiveOutcomeText: "\u0438 \u043E\u0431\u0445\u043E\u0434\u043D\u043E\u0439
      \u043C\u0430\u043D\u0451\u0432\u0440 \u043F\u0440\u043E\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F.
      \u0421\u0440\u0435\u0434\u0438 \u0432\u0435\u0449\u0435\u0439 \u2014 [support]
      \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0445\u0438\u0442\u0440\u043E\u0441\u0442\u044C
      \u043D\u0435 \u0437\u0430\u043C\u0435\u043D\u044F\u0435\u0442 \u0445\u043E\u0440\u043E\u0448\u0435\u0439
      \u0431\u0440\u043E\u043D\u0438. \u0422\u044B \u0432\u044B\u0440\u044B\u0432\u0430\u0435\u0448\u044C\u0441\u044F
      \u0441 \u043F\u043E\u0442\u0435\u0440\u044F\u043C\u0438."
  - approachArchetype: 2
    supportArchetype: 2
    bonusChance: -0.15
    positiveOutcomeText: "\u0438 \u0441\u043B\u043E\u0432\u0430 \u043D\u0430 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u0438\u0435
      \u043E\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u044E\u0442
      \u0438\u0445. \u0422\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
      [support]."
    negativeOutcomeText: "\u043D\u043E \u0448\u0430\u0439\u043A\u0430 \u043D\u0435
      \u0441\u043B\u0443\u0448\u0430\u0435\u0442. \u0422\u044B \u0432\u044B\u0440\u044B\u0432\u0430\u0435\u0448\u044C\u0441\u044F,
      \u0445\u043E\u0442\u044F \u0438 \u0440\u0430\u043D\u0435\u043D."
