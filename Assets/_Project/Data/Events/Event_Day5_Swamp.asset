  m_Name: Event_Day5_Swamp
  m_EditorClassIdentifier: Assembly-CSharp::Story.Data.EventSO
  eventText: "\u0411\u0435\u0437 \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043E\u043A
    \u0442\u044B \u0437\u0430\u0431\u0440\u0451\u043B \u0432 \u0431\u043E\u043B\u043E\u0442\u043E.
    \u0422\u0440\u044F\u0441\u0438\u043D\u0430 \u0447\u0430\u0432\u043A\u0430\u0435\u0442
    \u043F\u043E\u0434 \u043D\u043E\u0433\u0430\u043C\u0438, \u0442\u0443\u043C\u0430\u043D
    \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u0442\u0440\u043E\u043F\u0443."
  totalPenalty: -18
  actionVerb: "\u041F\u0440\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F"
  actionVerbPast: "\u043F\u0440\u043E\u0431\u0438\u0440\u0430\u0435\u0448\u044C\u0441\u044F"
  defaultApproachAdverb: "\u0442\u0435\u0440\u043F\u0435\u043B\u0438\u0432\u043E"
  defaultApproachAdverbPast: "\u0442\u0435\u0440\u043F\u0435\u043B\u0438\u0432\u043E"
  defaultHpWeight: 2
  defaultPowWeight: 1
  defaultSanWeight: 2
  defaultSupportAdverb: "\u0441\u0438\u043B\u043E\u0439"
  defaultPenaltyReduction: 0
  baseChance: 0.25
  positiveOutcomeText: "\u0438 \u0442\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0448\u044C
    \u0442\u0432\u0451\u0440\u0434\u0443\u044E \u043F\u043E\u0447\u0432\u0443. \u041D\u0430
    \u043A\u043E\u0447\u043A\u0435 \u043B\u0435\u0436\u0438\u0442 [support] \u0438
    [support]."
  negativeOutcomeText: "\u043D\u043E \u0431\u043E\u043B\u043E\u0442\u043E \u0437\u0430\u0442\u044F\u0433\u0438\u0432\u0430\u0435\u0442
    \u0433\u043B\u0443\u0431\u0436\u0435. \u0422\u044B \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0448\u044C\u0441\u044F
    \u0441 \u0442\u0440\u0443\u0434\u043E\u043C."
  synergies:
  - approachArchetype: 0
    supportArchetype: 0
    bonusChance: 0.2
    positiveOutcomeText: "\u0438 \u0442\u044B \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0435\u0448\u044C\u0441\u044F
      \u0447\u0435\u0440\u0435\u0437 \u0442\u0440\u044F\u0441\u0438\u043D\u0443.
      \u041D\u0430 \u043A\u043E\u0447\u043A\u0435 \u043B\u0435\u0436\u0438\u0442
      [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0441\u0438\u043B\u0430 \u0438\u0441\u0442\u043E\u0449\u0430\u0435\u0442\u0441\u044F
      \u0432 \u0431\u043E\u043B\u043E\u0442\u0435. \u0422\u044B \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0448\u044C\u0441\u044F
      \u0441 \u0442\u0440\u0443\u0434\u043E\u043C."
  - approachArchetype: 1
    supportArchetype: 0
    bonusChance: 0.15
    positiveOutcomeText: "\u0438 \u0442\u044F\u0436\u0451\u043B\u044B\u0439 \u043A\u0430\u043C\u0435\u043D\u044C
      \u043A\u0430\u043A \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440. \u041D\u0430
      \u043F\u0443\u0442\u0438 \u043B\u0435\u0436\u0438\u0442 [support] \u0438 [support]."
    negativeOutcomeText: "\u043D\u043E \u0445\u0438\u0442\u0440\u043E\u0441\u0442\u044C
      \u043D\u0435 \u0437\u043D\u0430\u0435\u0442 \u043E\u0431\u0445\u043E\u0434\u043D\u044B\u0445
      \u043F\u0443\u0442\u0435\u0439. \u0422\u044B \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0448\u044C\u0441\u044F
      \u0441 \u0442\u0440\u0443\u0434\u043E\u043C."
  - approachArchetype: 2
    supportArchetype: 2
    bonusChance: -0.15
    positiveOutcomeText: "\u0438 \u0447\u0443\u0434\u043E\u043C \u0443\u0445\u043E\u0434\u0438\u0448\u044C.
      \u0412\u043F\u0435\u0440\u0435\u0434\u0438 \u2014 [support]."
    negativeOutcomeText: "\u043D\u043E \u0441\u043B\u043E\u0432\u0430 \u043D\u0435
      \u0434\u0435\u043B\u0430\u044E\u0442 \u0442\u0440\u043E\u043F\u0443. \u0411\u043E\u043B\u043E\u0442\u043E
      \u0437\u0430\u0442\u044F\u0433\u0438\u0432\u0430\u0435\u0442 \u0433\u043B\u0443\u0431\u0436\u0435."
