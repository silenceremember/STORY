  eventText: "\u041F\u0435\u0440\u0435\u0434 \u0432\u044B\u0445\u043E\u0434\u043E\u043C
    \u0442\u044B \u0437\u0430\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u0435\u0448\u044C
    \u0432 \u043B\u0430\u0432\u043A\u0443. \u0421\u0442\u0430\u0440\u0438\u043A \u0440\u0430\u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442
    \u0442\u043E\u0432\u0430\u0440\u044B \u043D\u0430 \u043F\u0440\u0438\u043B\u0430\u0432\u043A\u0435
    \u0438 \u0449\u0443\u0440\u0438\u0442\u0441\u044F: \xAB\u0411\u0435\u0440\u0438,
    \u043F\u0443\u0442\u043D\u0438\u043A, \u0434\u043E\u0440\u043E\u0433\u0430 \u0434\u043B\u0438\u043D\u043D\u0430\u044F.\xBB"
